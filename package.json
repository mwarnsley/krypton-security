{
  "name": "krypton-security",
  "version": "1.0.0",
  "description": "",
  "packageManager": "npm@10.8.2",
  "engines": {
    "node": "20.19.4"
  },
  "main": "index.js",
  "scripts": {
    "dev": "npm run dev:dashboard",
    "dev:dashboard": "next dev src/dashboard",
    "dev:daemon": "cargo run --manifest-path src/core-native/Cargo.toml",
    "dev:full": "concurrently --kill-others-on-fail --names daemon,dashboard \"npm:dev:daemon\" \"npm:dev:dashboard\"",
    "build": "next build src/dashboard",
    "format": "prettier --write \"**/*.{tsx,ts,json,md}\"",
    "format:check": "prettier --check \"**/*.{tsx,ts,json,md}\"",
    "format:rust": "cargo fmt --manifest-path src/core-native/Cargo.toml",
    "format:rust:check": "cargo fmt --manifest-path src/core-native/Cargo.toml --check",
    "lint": "eslint . --max-warnings=0",
    "lint:rust": "cargo clippy --manifest-path src/core-native/Cargo.toml --all-targets --all-features -- -D warnings",
    "typecheck": "tsc --noEmit && tsc --noEmit --project src/dashboard/tsconfig.json",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:rust": "cargo test --manifest-path src/core-native/Cargo.toml --all-targets --all-features",
    "test:sim": "ts-node tests_simulation/test_injection.ts",
    "test:unit": "vitest run",
    "rust:fmt": "cargo fmt --manifest-path src/core-native/Cargo.toml -- --check",
    "rust:clippy": "cargo clippy --manifest-path src/core-native/Cargo.toml --all-targets --all-features -- -D warnings",
    "rust:test": "cargo test --manifest-path src/core-native/Cargo.toml --all-targets --all-features",
    "design-system:check": "node scripts/check-design-system.cjs",
    "security:audit": "npm audit --audit-level=high",
    "release:preflight": "node scripts/release-preflight.cjs",
    "release:archive": "git archive --format=zip --output=krypton-security.zip HEAD",
    "release:inspect": "node scripts/inspect-release-archive.cjs krypton-security.zip",
    "release:package": "npm run release:preflight && npm run release:archive && npm run release:inspect",
    "benchmark:telemetry": "node scripts/benchmark-telemetry.cjs",
    "verify": "npm run lint && npm run typecheck && npm test -- --run && npm run build && npm run design-system:check && npm run rust:fmt && npm run rust:clippy && npm run rust:test"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mwarnsley/krypton-security.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/mwarnsley/krypton-security/issues"
  },
  "homepage": "https://github.com/mwarnsley/krypton-security#readme",
  "devDependencies": {
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitest/coverage-v8": "^4.1.10",
    "autoprefixer": "^10.5.3",
    "concurrently": "^9.2.1",
    "eslint": "^9.39.5",
    "eslint-config-next": "^16.2.10",
    "eslint-config-prettier": "^10.1.8",
    "postcss": "^8.5.19",
    "prettier": "^3.9.5",
    "tailwindcss": "^3.4.19",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "vitest": "^4.1.10"
  },
  "dependencies": {
    "@radix-ui/react-dropdown-menu": "^2.1.20",
    "@radix-ui/react-slot": "^1.3.0",
    "@radix-ui/react-switch": "^1.3.3",
    "@radix-ui/react-tooltip": "^1.2.12",
    "@tanstack/react-table": "^8.21.3",
    "clsx": "^2.1.1",
    "date-fns": "^4.4.0",
    "lucide-react": "^1.24.0",
    "next": "^16.2.10",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0"
  }
}
